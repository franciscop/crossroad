{
  "compilerOptions": {
    "target": "ES2021",
    "moduleResolution": "bundler",
    "jsx": "react",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "types": ["jest", "node"],
  },
  "include": ["src/**/*", "test/**/*"],
}
